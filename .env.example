# ── LLM provider ──────────────────────────────────────────────────────────────
# "claude" (default) or "ollama" (local, free)
LLM_PROVIDER=claude

# Required if LLM_PROVIDER=claude
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional — defaults to claude-sonnet-4-5
# ANTHROPIC_MODEL=claude-sonnet-4-5

# Required if LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ── Docker target ──────────────────────────────────────────────────────────────
# Absolute path to the docker-compose file for the service you want to watch
DOCKER_COMPOSE_FILE=/path/to/your/docker-compose.yml

# The service name inside that compose file
DOCKER_SERVICE_NAME=api

# ── Source code mapping ────────────────────────────────────────────────────────
# Host path to your app source code — used to read context around error lines
APP_SOURCE_PATH=/path/to/your/app

# The path prefix your container uses for the same code (used to map tracebacks)
# e.g. if tracebacks show /app/app/models/foo.py, set this to /app
APP_CONTAINER_PATH=/app

# ── Lifecycle ──────────────────────────────────────────────────────────────────
# How many hours of silence before an error is considered resolved
# Default: 48
ERROR_INACTIVE_AFTER_HOURS=48

# ── Output ────────────────────────────────────────────────────────────────────
# Where to write generated HTML reports
# Default: reports/
REPORTS_DIR=reports/

# ── GitHub integration (optional) ─────────────────────────────────────────────
# Required for: vigil github open-issue / vigil github list-issues
# Token needs issues:write scope only — target your app repo, not the Vigil repo
GITHUB_TOKEN=
GITHUB_REPO=your-username/your-app-repo
